//Better recombination() callback, from Schaal, Buffalo, Ralph & Kern: 
recombination() {
	gm1 = genome1.containsMarkerMutation(m6, 11097496);  //half way through intergenic region near halfway point of chromosome
	gm2 = genome2.containsMarkerMutation(m6,  16091269); //half way through the intergenic region nearly 5Mb away with 227 genes in between
	hom_breaks = breakpoints[breakpoints <= 22019000];//breakpoints on chromosome with inversion
	nonHom_breaks = breakpoints[breakpoints > 22019000];//breakpoints on nonhomologous chromosome
	
	if (!(gm1 | gm2)) {
		// homozygote non-inverted 
		//catn(c(sim.cycle,gm1,gm2,"Hom-Std", length(breakpoints), length(hom_breaks), length(nonHom_breaks)));
		return F;
	}
	
	inInv = (breakpoints > 11097496) & (breakpoints <= 16091269);
	//new draw enters here!
	if (sum(inInv) == 0) {
		//breakpoints are even inside inversion; so all OK
		//catn(c(sim.cycle,gm1,gm2,"HetF", breakpoints, length(breakpoints), length(hom_breaks), sum(inInv), length(nonHom_breaks)));
		return F;
	}
	
	if (gm1 & gm2) {
		// homozygote inverted 
		left = (breakpoints == 11097496);
		right = (breakpoints == 16091269 + 1);
		breakpoints = sort(c(breakpoints[!(left | right)], c(11097496, 16091269 + 1)[c(sum(left) == 0, sum(right) == 0)]));
		//catn(c(sim.cycle,gm1,gm2,"Hom-Inv", breakpoints, length(breakpoints), length(hom_breaks), length(nonHom_breaks)));
		return F;
	} else {
		// heterozygote inverted: resample to get an even # of breakpoints 
		// this is *recursive*: it calls this recombination callback again! 
		//catn(c(sim.cycle,gm1,gm2,"HetT",breakpoints, length(breakpoints), length(hom_breaks), sum(inInv), length(nonHom_breaks)));
		//breakpoints = sim.chromosome.drawBreakpoints(individual);
		breakpoints = breakpoints[!inInv];
	}
	//inversion heterozygote
	hom_breaks = breakpoints[breakpoints <= 22019000];//breakpoints on chromosome with inversion
	nonHom_breaks = breakpoints[breakpoints > 22019000];//breakpoints on nonhomologous chromosomes
	//catn(c(sim.cycle,gm1,gm2,"new draw",breakpoints, length(breakpoints), length(hom_breaks),  length(nonHom_breaks)));
	return T;
}

