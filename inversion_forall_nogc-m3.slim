//-------------------------------------------------------------------
// Define the recombination callback to prevent crossing over to happens when an individual is carrying a copy of each arrangement (tracked through the m6 position). It prevents the formation of a breakpoints in the inversion region.  
//-------------------------------------------------------------------
//recombination() {
//	if (genome1.containsMarkerMutation(m6, 60000) == genome2.containsMarkerMutation(m6, 60000))
//		return F;
//	inv = (breakpoints > 50000) & (breakpoints < 80000);
//	if (sum(inv) == 0)
//		return F;
//	breakpoints = breakpoints[!inv];

//	return T;
//}

//Better recombination() callback, from Schaal, Buffalo, Ralph & Kern: 
recombination() {
	gm1 = genome1.containsMarkerMutation(m6, 55047499);  //half way through intergenic region near halfway point of chromosome 2R (55047499)
	gm2 = genome2.containsMarkerMutation(m6,  60019275); //half way through the intergenic region nearly 5Mb away with 227 genes in between
	//split breakpoints into each chromosome
	chrX = breakpoints[(breakpoints <= 22018999)];//breakpoints on chrX
	twoL = breakpoints[(breakpoints >= 22019000) & (breakpoints <= 44037999)];//breakpoints on same chromosome ARM as inversion (chr 2L)
	twoR = breakpoints[(breakpoints >= 44038000) & (breakpoints <= 66056999)] ;//breakpoints on chromosome with inversion (chr 2R)
	three = breakpoints[breakpoints >= 66057000];//breakpoints on nonhomologous chromosomes (chr 3L and 3R)
	//catn(c(sim.cycle,gm1,gm2,"BP:",breakpoints, "X:",chrX,"2R:",twoR,"2L:",twoL,"3:",three));
	
	if (!(gm1 | gm2)) {
		// homozygote non-inverted 
		//catn(c(sim.cycle,gm1,gm2,"Hom-Std", length(breakpoints), length(hom_breaks), length(hom_arm_breaks),length(nonHom_breaks), breakpoints,"K1:",keep1,"K2:",keep2,"K3:",keep3));
		//make vectors to modify rates
		keepX = asLogical(rbinom(length(chrX), 1, 0.8129));    // decide which to keep from X (Inter-chromosomal effect)
		keep2L = asLogical(rbinom(length(twoL), 1, 0.8129));    // decide which to keep from 2L (Intra-chromosomal effect)
		keep2R = asLogical(rbinom(length(twoR), 1, 0.8129));    // decide which to keep from 2R (local effect decay with distance-ish)
		keep3 = asLogical(rbinom(length(three), 1, 0.8129));    // decide which to keep from 3L and 3R (Inter-chromosomal effect)
		
		breakpoints = sort(c(chrX[keepX],twoL[keep2L],twoR[keep2R],three[keep3]));
		return T;    // changed the breakpoints
		//return F;
	}
	
	if (gm1 & gm2) {
		// homozygote inverted 
		//make vectors to modify rates
		keepX = asLogical(rbinom(length(chrX), 1, 0.8129));    // decide which to keep from X (Inter-chromosomal effect)
		keep2L = asLogical(rbinom(length(twoL), 1, 0.8129));    // decide which to keep from 2L (Intra-chromosomal effect)
		keep2R = asLogical(rbinom(length(twoR), 1, 0.8129));    // decide which to keep from 2R (local effect decay with distance-ish)
		keep3 = asLogical(rbinom(length(three), 1, 0.8129));    // decide which to keep from 3L and 3R (Inter-chromosomal effect)
		
		breakpoints = sort(c(chrX[keepX],twoL[keep2L],twoR[keep2R],three[keep3]));
		
		left = (breakpoints == 55047499);
		right = (breakpoints == 60019275 + 1);
		
		breakpoints = sort(c(breakpoints[!(left | right)], c(55047499, 60019275 + 1)[c(sum(left) == 0, sum(right) == 0)]));
		//catn(c(sim.cycle,gm1,gm2,"Hom-Inv", breakpoints, length(breakpoints), length(hom_breaks), length(nonHom_breaks)));
		return T;
	} //else {
	
	if (gm1 | gm2) {
		//inversion  heterozygote
		inInv = (breakpoints > 55047499) & (breakpoints <= 60019275);
		//remove breakpoints inside inversion
		breakpoints = breakpoints[!inInv];
		//redefine twoR breakpoints
		twoR = breakpoints[(breakpoints >= 44038000) & (breakpoints <= 66056999)] ;//breakpoints on chromosome with inversion (chr 2R)

		//catn(c(sim.cycle, breakpoints,inInv));
		//new draw enters here!
		//if (sum(inInv) == 0) {
		//breakpoints are even inside inversion; so all OK
		//make vectors to modify rates
		//keepX = asLogical(rbinom(length(chrX), 1, 1.0));    // decide which to keep from X (Inter-chromosomal effect)
		keep2L = asLogical(rbinom(length(twoL), 1, 0.9245));    // decide which to keep from 2L (Intra-chromosomal effect)
		keep2R = asLogical(rbinom(length(twoR), 1, 0.0084));    // decide which to keep from 2R (local effect decay with distance-ish)
		keep3 = asLogical(rbinom(length(three), 1, 0.8705));    // decide which to keep from 3L and 3R (Inter-chromosomal effect)
		
		breakpoints = sort(c(chrX,twoL[keep2L],twoR[keep2R],three[keep3]));
		//catn(c(sim.cycle,gm1,gm2,"HetF", breakpoints));
		return T;
		//}
	}
	return T;
}

