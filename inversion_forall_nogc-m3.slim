1000001 late() {
	//	sim.outputMutations(sim.mutationsOfType(m6),filePath="./inversion_counts.txt",append=T);
	sim.outputMutations(sim.mutationsOfType(m5),filePath="./del_mutations.txt");
	sim.outputFixedMutations(filePath="./del_mutations.txt",append=T);
	//	writeFile("./fitness_p1.txt",paste(sim.cycle),append=T);
	//p1fit=p1.cachedFitness(NULL);
	p1fit=sim.getValue("p1fit");
	//	writeFile("./fitness_p1.txt",paste(p1fit,sep=", "),append=T);
	g1fit=p1.individuals.countOfMutationsOfType(m6);
	//	writeFile("./fitness_p1.txt",paste(g1fit,sep=", "),append=T);
	//	sim.outputFixedMutations(filePath="./inversion_data_fm.txt");
	sim.simulationFinished();
}

