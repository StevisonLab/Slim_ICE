// read the burn in file and create the inversion in individual -indv- in haplotype -haplo-. These two values are provided in the slim call.
500000 late () {
	sim.readFromPopulationFile("../burn_in.txt");
	target=p1.individuals[indv];
	gen=target.genomes[haplo];
	//Berdan et al only had the below line
	//gen.addNewDrawnMutation(m6,60000);
	//BUT, updated manual suggests two lines of code to add inversion with first line at start and second line at end
	gen.addNewDrawnMutation(m6,50000);
	gen.addNewDrawnMutation(m6,80000);
}

// Define the fitness fucntion callback to provide a fitness advaantage of 1.03 to heterokyryotypes individuals
500000:1000001 mutationEffect(m6){
	if (individual.genome1.countOfMutationsOfType(m6)+individual.genome2.countOfMutationsOfType(m6)==2)
		return s_het;
	else
		return effect;
}

// To avoid error message, cached fitness moved to an early block and output mutations is in a late block
500002:510000 early() {
	if (sim.cycle % 200 == 0) {
		//p1fit=p1.cachedFitness(NULL);
		sim.setValue("p1fit",p1.cachedFitness(NULL));
	}
	// Check consition to stop the simulations if the inversion is either lost or fixed in the whole populations. Export the final stage of the final status of the popuation.
	if (sim.countOfMutationsOfType(m6)==0){
		sim.setValue("p1fit",p1.cachedFitness(NULL));
	}
}
// Tracking the really early stage of the simulation, with the fitness of the whole population and the frequency of the inversion being output every 200 generations.
500002:510000 late() {
	if (sim.cycle % 200 == 0) {
		sim.outputMutations(sim.mutationsOfType(m6),filePath="./inversion_counts.txt",append=T);
		writeFile("./fitness_p1.txt",paste(sim.cycle),append=T);
		p1fit=sim.getValue("p1fit");
		//p1fit=p1.cachedFitness(NULL);
		writeFile("./fitness_p1.txt",paste(p1fit,sep=", "),append=T);
		g1fit=p1.individuals.countOfMutationsOfType(m6);
		writeFile("./fitness_p1.txt",paste(g1fit,sep=", "),append=T);
	}
	// Check consition to stop the simulations if the inversion is either lost or fixed in the whole populations. Export the final stage of the final status of the popuation.
	if (sim.countOfMutationsOfType(m6)==0){
		sim.outputMutations(sim.mutationsOfType(m6),filePath="./inversion_counts.txt",append=T);
		sim.outputMutations(sim.mutationsOfType(m5),filePath="./del_mutations.txt",append=T);
		writeFile("./fitness_p1.txt",paste(sim.cycle),append=T);
		//p1fit=p1.cachedFitness(NULL);
		p1fit=sim.getValue("p1fit");
		writeFile("./fitness_p1.txt",paste(p1fit,sep=", "),append=T);
		g1fit=p1.individuals.countOfMutationsOfType(m6);
		writeFile("./fitness_p1.txt",paste(g1fit,sep=", "),append=T);
		sim.outputFixedMutations(filePath="./inversion_data_fm.txt");
		catn(c(sim.cycle,"Inversion Lost!"));
		sim.simulationFinished();
	}
}

